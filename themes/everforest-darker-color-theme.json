  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7A8478",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation comment",
      "scope": [
        "comment.block.documentation",
        "comment.documentation",
        "string.quoted.docstring"
      ],
      "settings": {
        "foreground": "#859289",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation comment tag",
      "scope": [
        "comment.block.documentation keyword",
        "comment.block.documentation storage.type.class",
        "keyword.other.documentation"
      ],
      "settings": {
        "foreground": "#83C092",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#A7C080"
      }
    },
    {
      "name": "String escape",
      "scope": [
        "constant.character.escape",
        "constant.character.escape.backslash"
      ],
      "settings": {
        "foreground": "#DBBC7F"
      }
    },
    {
      "name": "Regular expression",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#83C092"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#D699B6"
      }
    },
    {
      "name": "Language constant",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#D699B6"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "variable.other.constant",
        "constant.other",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#D699B6"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#E67E80",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#E67E80",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#E69875"
      }
    },
    {
      "name": "Function declaration and call",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#7FBBB3"
      }
    },
    {
      "name": "Static method",
      "scope": [
        "entity.name.function.static",
        "meta.function-call.static"
      ],
      "settings": {
        "foreground": "#7FBBB3",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Class, type, and interface names",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.type.class",
        "support.class",
        "support.type",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#DBBC7F"
      }
    },
    {
      "name": "Interface name",
      "scope": [
        "entity.name.type.interface",
        "entity.name.interface"
      ],
      "settings": {
        "foreground": "#DBBC7F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable and identifier",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#D3C6AA"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "variable.parameter.function"
      ],
      "settings": {
        "foreground": "#D3C6AA",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Instance and object property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#83C092"
      }
    },
    {
      "name": "Annotation and decorator",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "storage.type.annotation",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#83C092"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "meta.brace.round",
        "meta.brace.square",
        "punctuation.section.block"
      ],
      "settings": {
        "foreground": "#D3C6AA"
      }
    },
    {
      "name": "Markup and HTML tag",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#E69875"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#83C092"
      }
    },
    {
      "name": "HTML entity",
      "scope": [
        "constant.character.entity",
        "punctuation.definition.entity"
      ],
      "settings": {
        "foreground": "#D699B6"
      }
    },
    {
      "name": "Label",
      "scope": [
        "entity.name.label",
        "keyword.control.label"
      ],
      "settings": {
        "foreground": "#7FBBB3"
      }
    },
    {
      "name": "Predefined symbol",
      "scope": [
        "support.type.builtin",
        "support.constant",
        "variable.language"
      ],
      "settings": {
        "foreground": "#DBBC7F"
      }
    },
    {
      "name": "Namespace",
      "scope": [
        "entity.name.namespace",
        "entity.name.module"
      ],
      "settings": {
        "foreground": "#DBBC7F"
      }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#A7C080",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#E69875",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#E69875",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.inline.raw",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#DBBC7F"
      }
    },
    {
      "name": "Markdown link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#7FBBB3"
      }
    },
    {
      "name": "Markdown list punctuation",
      "scope": [
        "markup.list punctuation.definition.list.begin",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#E69875"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#F85552"
      }
    }
  ],
  "semanticTokenColors": {
    "parameter": {
      "foreground": "#D3C6AA",
      "fontStyle": "italic"
    },
    "property": "#83C092",
    "property.static": {
      "foreground": "#83C092",
      "fontStyle": "italic"
    },
    "variable.constant": "#D699B6",
    "class": "#DBBC7F",
    "interface": {
      "foreground": "#DBBC7F",
      "fontStyle": "italic"
    },
    "enum": "#DBBC7F",
    "enumMember": "#D699B6",
    "type": "#DBBC7F",
    "namespace": "#DBBC7F",
    "function": "#7FBBB3",
    "function.static": {
      "foreground": "#7FBBB3",
      "fontStyle": "italic"
    },
    "method": "#7FBBB3",
    "macro": "#83C092",
    "decorator": "#83C092",
    "keyword": {
      "foreground": "#E67E80",
      "fontStyle": "bold"
    }
  }
}
